# Biassemble Backend — Environment Variables (server-only, never expose to frontend)
# Copy to .env.local for local development.

# Supabase Postgres connection string
DATABASE_URL=

# Google AI Studio — Gemini Flash 2.0 (https://aistudio.google.com)
GOOGLE_GENERATIVE_AI_API_KEY=

# Inngest (durable workflows)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Optional: allow frontend origin in dev (comma-separated)
CORS_ORIGIN=http://localhost:5173
