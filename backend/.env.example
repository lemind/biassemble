# Biassemble Backend — Environment Variables (server-only)
# Copy to .env.local for local development.

# Supabase Postgres
DATABASE_URL=

# Inngest (background jobs)
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# AI: dev-mock (local, no Core) | core (production → private AI Core service)
AI_CLIENT_MODE=dev-mock
AI_CORE_BASE_URL=
AI_CORE_API_KEY=

# Optional: frontend origin in dev
CORS_ORIGIN=http://localhost:5173

# Prompts and LLM keys live in biassemble-core (private repo) — not here.
